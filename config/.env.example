# Emby 缺集检测系统 - 配置文件
# 复制此文件为 .env 并填入实际值

# ==================== Emby 配置 ====================
EMBY_HOST=http://localhost:8096
EMBY_API_KEY=your_api_key_here

# ==================== TMDB 配置 ====================
TMDB_API_KEY=your_tmdb_api_key
TMDB_LANGUAGE=zh-CN

# ==================== 检测配置 ====================
CHECK_INTERVAL_MINUTES=60
NOTIFY_ON_COMPLETE=true
SCAN_ON_STARTUP=false

# ==================== QQ 通知 ====================
QQ_BOT_ENABLED=false
QQ_BOT_WEBHOOK_URL=

# ==================== 邮件通知 ====================
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# ==================== Telegram 通知 ====================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=Markdown

# ==================== Web 界面配置 ====================
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET_KEY=your_secret_key_here

# ==================== 代理配置 ====================
PROXY_ENABLED=false
PROXY_HTTP=
PROXY_HTTPS=

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/emby-detector.log
